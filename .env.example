# Public production URL used for canonical URLs, sitemap entries, and schema.
NEXT_PUBLIC_SITE_URL=https://orxivo.com

# Google Search Console HTML tag verification value only (no fake ID).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Connect the contact form to your preferred CRM/form endpoint before launch.
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# Optional public social profile URLs used in Organization schema.
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_X_URL=
